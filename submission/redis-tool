#!/usr/bin/env python3

import sys
import subprocess
import shutil
import re
sys.stdout.reconfigure(line_buffering=True) 

# -------------------------
# PREREQUISITE CHECK
# -------------------------
def check_prerequisites():
    errors = []

    # Check Container Runtime (prefer Podman)
    if shutil.which("podman"):
        result = subprocess.run(["podman", "--version"], capture_output=True, text=True)
        version = result.stdout.strip().split()[-1]
        print(f"✓ Podman {version} found")

    elif shutil.which("docker"):
        result = subprocess.run(["docker", "--version"], capture_output=True, text=True)
        version = result.stdout.strip().split()[2].rstrip(",")
        print(f"✓ Docker {version} found")

    else:
        errors.append(
            "✗ Container runtime not found (Docker or Podman)\n"
            "  Install Podman: https://podman.io/docs/installation\n"
            "  Install Docker: https://docs.docker.com/engine/install/"
        )

    # Check Ansible >= 2.14
    if shutil.which("ansible-playbook"):
        result = subprocess.run(["ansible-playbook", "--version"], capture_output=True, text=True)
        first_line = result.stdout.splitlines()[0]
        version_match = re.search(r"(\d+\.\d+[\.\d]*)", first_line)

        if version_match:
            version_str = version_match.group(1)
            major, minor = int(version_str.split(".")[0]), int(version_str.split(".")[1])

            if major > 2 or (major == 2 and minor >= 14):
                print(f"✓ Ansible {version_str} found")
            else:
                errors.append(
                    f"✗ Ansible {version_str} found but version 2.14+ is required\n"
                    "  Upgrade: pip install --upgrade ansible"
                )
    else:
        errors.append(
            "✗ Ansible not found\n"
            "  Install: pip install ansible  (or use your OS package manager)"
        )

    if errors:
        for err in errors:
            print(err)
        print("\nPlease install the missing dependencies and retry.")
        sys.exit(1)

    print("Proceeding...\n")


# -------------------------
# DATA SEED
# -------------------------
def handle_seed(args):

    keys = 1000

    if "--keys" in args:
        keys = int(args[args.index("--keys") + 1])

    print(f"\nSeeding {keys} keys into Redis Cluster via Ansible...\n")

    subprocess.run([
        "ansible-playbook",
        "-i", "ansible/inventory/hosts.ini",
        "ansible/playbooks/data_seed.yml",
        "-e", f"seed_keys={keys}"
    ])


# -------------------------
# DATA VERIFY
# -------------------------
def handle_verify():

    print("\nVerifying keys in Redis Cluster via Ansible...\n")

    subprocess.run([
        "ansible-playbook",
        "-i", "ansible/inventory/hosts.ini",
        "ansible/playbooks/data_verify.yml"
    ])


# -------------------------
# STATUS
# -------------------------
def handle_status():

    print("\nFetching Redis Cluster Status via Ansible...\n")

    subprocess.run([
        "ansible-playbook",
        "-i", "ansible/inventory/hosts.ini",
        "ansible/playbooks/status.yml"
    ])


# -------------------------
# CLI PARSER
# -------------------------
args = sys.argv[1:]

# Must run before anything else
check_prerequisites()

module = args[0] if len(args) > 0 else None
action = args[1] if len(args) > 1 else None


# -------------------------
# DATA COMMAND ROUTER
# -------------------------
if module == "data":
    if action == "seed":
        handle_seed(args)
    elif action == "verify":
        handle_verify()


# -------------------------
# STATUS COMMAND ROUTER
# -------------------------
if module == "status":
    handle_status()


# -------------------------
# PROVISION FLOW
# -------------------------
if module == "provision":

    version = None
    masters = None
    replicas = None

    for i in range(len(args)):
        if args[i] == "--version":
            version = args[i + 1]
        if args[i] == "--masters":
            masters = args[i + 1]
        if args[i] == "--replicas-per-master":
            replicas = args[i + 1]

    subprocess.run([
        "ansible-playbook",
        "-i", "ansible/inventory/hosts.ini",
        "ansible/playbooks/provision.yml"
    ])

    print("\nRedis Installed")
    print("Redis Configured for Cluster Mode")
    print("Redis Started on all nodes")
    print("\nVersion:", version)
    print("Masters:", masters)
    print("Replicas per master:", replicas)

    print("\nFINAL CLUSTER TOPOLOGY\n")

    subprocess.run([
        "redis-cli",
        "-c",
        "-h", "127.0.0.1",
        "-p", "6379",
        "cluster", "nodes"
    ])

    print("\nCONNECTIVITY STATUS\n")

    subprocess.run([
        "redis-cli",
        "-c",
        "-h", "127.0.0.1",
        "-p", "6379",
        "cluster", "info"
    ])
