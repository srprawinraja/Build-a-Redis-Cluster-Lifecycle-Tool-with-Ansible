def check_prerequisites():
    errors = []

    # Check Container Runtime (prefer Podman)
    if shutil.which("podman"):
        result = subprocess.run(["podman", "--version"], capture_output=True, text=True)
        version = result.stdout.strip().split()[-1]
        print(f"✓ Podman {version} found")

    elif shutil.which("docker"):
        result = subprocess.run(["docker", "--version"], capture_output=True, text=True)
        version = result.stdout.strip().split()[2].rstrip(",")
        print(f"✓ Docker {version} found")

    else:
        errors.append(
            "✗ Container runtime not found (Docker or Podman)\n"
            "  Install Podman: https://podman.io/docs/installation\n"
            "  Install Docker: https://docs.docker.com/engine/install/"
        )

    # Check Ansible >= 2.14
    if shutil.which("ansible-playbook"):
        result = subprocess.run(["ansible-playbook", "--version"], capture_output=True, text=True)
        first_line = result.stdout.splitlines()[0]
        version_match = re.search(r"(\d+\.\d+[\.\d]*)", first_line)

        if version_match:
            version_str = version_match.group(1)
            major, minor = int(version_str.split(".")[0]), int(version_str.split(".")[1])

            if major > 2 or (major == 2 and minor >= 14):
                print(f"✓ Ansible {version_str} found")
            else:
                errors.append(
                    f"✗ Ansible {version_str} found but version 2.14+ is required\n"
                    "  Upgrade: pip install --upgrade ansible"
                )
    else:
        errors.append(
            "✗ Ansible not found\n"
            "  Install: pip install ansible  (or use your OS package manager)"
        )

    if errors:
        for err in errors:
            print(err)
        print("\nPlease install the missing dependencies and retry.")
        sys.exit(1)

    print("Proceeding...\n")


def crc16(data: bytes) -> int:
    crc = 0
    for byte in data:
        crc ^= byte << 8
        for _ in range(8):
            if crc & 0x8000:
                crc = (crc << 1) ^ 0x1021
            else:
                crc = crc << 1
            crc &= 0xFFFF
    return crc

def get_slot(key: str) -> int:
    start = key.find('{')
    if start != -1:
        end = key.find('}', start + 1)
        if end != -1:
            key = key[start + 1:end]
    return crc16(key.encode('utf-8')) % 16384

def get_stable_masters(container_cli):
    import time
    for _ in range(15):
        res = subprocess.run(
            [container_cli, "exec", "redis-node-1", "redis-cli", "-h", "127.0.0.1", "-p", "6379", "cluster", "nodes"],
            capture_output=True, text=True
        )
        if res.returncode == 0:
            masters = []
            total_slots = 0
            for line in res.stdout.splitlines():
                if "master" in line:
                    parts = line.split()
                    if len(parts) >= 9:
                        addr = parts[1].split("@")[0]
                        if ":" in addr:
                            ip, port = addr.split(":")
                            slots = set()
                            for slot_part in parts[8:]:
                                if slot_part.startswith("["):
                                    continue
                                if "-" in slot_part:
                                    start_s, end_s = slot_part.split("-")
                                    for s in range(int(start_s), int(end_s) + 1):
                                        slots.add(s)
                                else:
                                    slots.add(int(slot_part))
                            total_slots += len(slots)
                            masters.append({"ip": ip, "port": port, "slots": slots})
            if total_slots == 16384:
                return masters
        time.sleep(1)
    return masters

def get_inventory_nodes():
    import os
    nodes = set()
    try:
        if os.path.exists("ansible/inventory/hosts.ini"):
            with open("ansible/inventory/hosts.ini", "r") as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith("[") and not line.startswith("#") and "ansible_host" in line:
                        parts = line.split()
                        if parts:
                            nodes.add(parts[0])
    except Exception:
        pass
    return sorted(list(nodes))

def log_operation(command, status, details):
    import datetime
    import json
    import os
    
    log_dir = "logs"
    if not os.path.exists(log_dir):
        os.makedirs(log_dir)
        
    log_entry = {
        "timestamp": datetime.datetime.now().isoformat(),
        "command": command,
        "status": status,
        "nodes": details.get("nodes", get_inventory_nodes()),
        "actions_taken": details.get("actions", []),
        "outcome": details.get("outcome", {})
    }
    
    # Save to a single operations log
    log_path = os.path.join(log_dir, "operations.json")
    try:
        entries = []
        if os.path.exists(log_path):
            with open(log_path, "r") as f:
                content = f.read().strip()
                if content:
                    entries = json.loads(content)
        entries.append(log_entry)
        with open(log_path, "w") as f:
            json.dump(entries, f, indent=2)
            
        # Also write a separate file for this command run
        sanitized_command = command.replace(" ", "_")
        time_str = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        single_path = os.path.join(log_dir, f"op_{time_str}_{sanitized_command}.json")
        with open(single_path, "w") as f:
            json.dump(log_entry, f, indent=2)
    except Exception as e:
        print(f"Error logging operation: {e}")

