def handle_seed(args):

    keys = 1000

    if "--keys" in args:
        keys = int(args[args.index("--keys") + 1])

    print(f"\nSeeding {keys} keys into Redis Cluster via Ansible...\n")

    res = subprocess.run([
        "ansible-playbook",
        "-i", "ansible/inventory/hosts.ini",
        "ansible/playbooks/data_seed.yml",
        "-e", f"seed_keys={keys}"
    ])
    status = "SUCCESS" if res.returncode == 0 else "FAILED"
    log_operation(
        "data seed",
        status,
        {
            "actions": [f"Seed {keys} keys into cluster"],
            "outcome": {"returncode": res.returncode, "keys_seeded": keys}
        }
    )


